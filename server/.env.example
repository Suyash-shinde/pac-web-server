# Server config
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=pac

# Auth (Phase 3)
JWT_SECRET=change-me-to-a-long-random-string

# Google OAuth (member sign-in). Create a Web client ID in Google Cloud Console.
# Must match VITE_GOOGLE_CLIENT_ID on the client. Leave blank to disable Google sign-in.
GOOGLE_CLIENT_ID=
